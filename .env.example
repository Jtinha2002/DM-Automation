# Use o "ID do app do Instagram" e a "Chave secreta do app do Instagram"
# encontrados em: Meta → seu app → Instagram → Configuração da API com login do Instagram
INSTAGRAM_APP_ID=your_instagram_app_id_here
INSTAGRAM_APP_SECRET=your_instagram_app_secret_here
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=your_random_verify_token_here
SESSION_SECRET=your_random_session_secret_here
BASE_URL=https://your-ngrok-url.ngrok-free.app
PORT=3000

# Senha do painel. Se vazio, o painel fica SEM senha (ok para teste local).
# OBRIGATÓRIO definir antes de hospedar online.
APP_PASSWORD=
